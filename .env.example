NEXT_PUBLIC_SITE_URL=http://localhost:7261
# Public deploys should set this to true so the umbrella site stays website-only.
NEXT_PUBLIC_PUBLIC_SITE_ONLY=false
# Filesystem fallback for local video playback and the profile photo volume path.
# Keep this pointed at a real mounted folder when you are not using bucket storage.
VIDEO_ASSET_ROOT=videos
# Optional bucket mode for large video uploads and public playback.
# When these are set, the video uploader switches to presigned bucket uploads.
VIDEO_BUCKET_NAME=
VIDEO_BUCKET_REGION=
VIDEO_BUCKET_ENDPOINT=
VIDEO_BUCKET_ACCESS_KEY_ID=
VIDEO_BUCKET_SECRET_ACCESS_KEY=
# Optional if you want /api/videos/[slug] to redirect straight to the public bucket URL.
VIDEO_BUCKET_PUBLIC_BASE_URL=
# Usually true for Railway Buckets and other S3-compatible services.
VIDEO_BUCKET_FORCE_PATH_STYLE=true
# Production should use a hosted libsql database (for example Turso)
LEAD_DATABASE_URL=file:./data/leads.db
# LEAD_DATABASE_AUTH_TOKEN=
# Run `npm run setup:env` to create a local .env.local with generated secrets.
LEAD_ENCRYPTION_KEY=replace-with-a-long-random-secret

ADMIN_USERNAME=replace-with-admin-username
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD_SALT=replace-with-a-long-random-salt
ADMIN_PASSWORD_HASH=replace-with-scrypt-hex-hash
# Optional: set this if you want the admin cookie shared across subdomains such as manage.devcandoit.com.
# ADMIN_COOKIE_DOMAIN=.devcandoit.com

GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_INBOX=devinotto26@gmail.com
CONTACT_TAG=DEV_CANDO_IT_LEAD

# Optional: set these to protect /Venus behind a private login page.
# When both are set, /Venus and its supporting Venus media endpoints require a Venus session.
VENUS_GATE_USERNAME=
VENUS_GATE_PASSWORD=
# Optional: defaults to ADMIN_SESSION_SECRET if omitted, but you can set a dedicated secret if preferred.
VENUS_GATE_SESSION_SECRET=
