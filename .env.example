# Public site URL used for redirects and canonical metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:7261
# Set to true in production so the umbrella site stays website-only.
NEXT_PUBLIC_PUBLIC_SITE_ONLY=false
# Exact origins allowed to perform authenticated or state-changing browser requests.
TRUSTED_MUTATION_ORIGINS=http://localhost:7261

# Internal TileOS service URL used by the /tileos/app proxy route.
TILEOS_INTERNAL_URL=http://127.0.0.1:9273
# Shared secret sent from the DevCanDoIt public proxy to the TileOS upstream.
TILEOS_PROXY_SHARED_SECRET=replace-with-a-long-random-secret
# Internal Trading Alerts service URL used by the /tradingalerts proxy route.
TRADING_ALERTS_INTERNAL_URL=http://127.0.0.1:2468
# Shared secret sent from the DevCanDoIt proxy to the Trading Alerts upstream.
TRADING_ALERTS_PROXY_SHARED_SECRET=replace-with-a-long-random-secret

# Local filesystem path used for media fallback and the profile-photo volume root.
VIDEO_ASSET_ROOT=videos

# Local auth-state database path. Production should point at a dedicated LibSQL database.
AUTH_STATE_DATABASE_URL=file:./data/auth-state.db
# Optional auth token for a remote auth-state LibSQL database.
AUTH_STATE_DATABASE_AUTH_TOKEN=

# Optional S3-compatible bucket settings for large video uploads.
VIDEO_BUCKET_NAME=
VIDEO_BUCKET_REGION=
VIDEO_BUCKET_ENDPOINT=
VIDEO_BUCKET_ACCESS_KEY_ID=
VIDEO_BUCKET_SECRET_ACCESS_KEY=
# Optional public bucket base URL if you want direct redirects for media playback.
VIDEO_BUCKET_PUBLIC_BASE_URL=
# Usually true for S3-compatible bucket providers.
VIDEO_BUCKET_FORCE_PATH_STYLE=true

# Local lead database path. Production can point at a hosted libsql database.
LEAD_DATABASE_URL=file:./data/leads.db
# Optional auth token for a remote libsql database.
LEAD_DATABASE_AUTH_TOKEN=
# Run `npm run setup:env` to generate local secrets in .env.local.
LEAD_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Admin login for private surfaces.
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD_SALT=replace-with-a-long-random-salt
ADMIN_PASSWORD_HASH=replace-with-scrypt-hex-hash
# Optional: share the admin cookie across subdomains like manage.devcandoit.com.
ADMIN_COOKIE_DOMAIN=.devcandoit.com

# Gmail SMTP for contact form delivery.
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_INBOX=replace-with-inbox-email
CONTACT_TAG=DEV_CANDO_IT_LEAD

# Firebase Admin service account for TeleMIDI public session create/join APIs.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional private Venus gate.
VENUS_GATE_USERNAME=
VENUS_GATE_PASSWORD_SALT=
VENUS_GATE_PASSWORD_HASH=
# Deprecated local-dev fallback only. Do not use in production.
VENUS_GATE_PASSWORD=
# Optional shared Venus sync storage root.
VENUS_DATA_ROOT=
